# ===========================================================================
# AI Journal (ai-blog) 環境変数サンプル
# このファイルをコピーして .env.local を作成してください。
#   cp .env.example .env.local
# DATABASE_URL は機密情報です。NEXT_PUBLIC_ を付けず、サーバー側のみで使用します。
# ===========================================================================

# --- ローカル開発（Cloud SQL に直接 TCP 接続する場合）---------------------
# Cloud SQL は TLS 必須（sslMode=ENCRYPTED_ONLY）。アプリ側で ssl を有効化済み。
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@104.198.125.182:5432/spm_dev_agent"

# --- Cloud Run 本番 --------------------------------------------------------
# 値は Secret Manager（spm-dev-agent-database-url:latest）から注入する。
# Cloud SQL Auth Proxy を使う場合の例:
#   DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/spm_dev_agent"
# パブリック IP 直結の場合の例（本リポジトリの既定）:
#   DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@104.198.125.182:5432/spm_dev_agent"
